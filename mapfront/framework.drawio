                <UserObject label="" mermaidData="{&#10;  &quot;data&quot;: &quot;flowchart TB\n    %% 样式定义\n    classDef frontend fill:#E3F2FD,stroke:#4A90E2,stroke-width:2px,color:#333\n    classDef backend fill:#F3E5F5,stroke:#7B1FA2,stroke-width:2px,color:#333\n    classDef agent fill:#FFF3E0,stroke:#9C27B0,stroke-width:1px,color:#333\n    classDef storage fill:#E8F5E9,stroke:#F57C00,stroke-width:2px,color:#333\n    classDef comms fill:#FAFAFA,stroke:#9E9E9E,stroke-width:2px,stroke-dasharray: 5 5,color:#333\n\n    %% User\n    User((User Researcher))\n\n    %% 前端模块\n    subgraph Frontend [Frontend View Vue3 + Vuex]\n        direction LR\n        LeftPanel[LeftPanel\\nPrompt Control / File Upload]\n        CenterPanel[CenterPanel\\nEnhancedRiverChart Visual]\n        RightPanel[RightPanel\\nDetailView / HypothesisView]\n        VuexStore[(Vuex Store\\nState Management)]\n        \n        LeftPanel &lt;--&gt; VuexStore\n        CenterPanel &lt;--&gt; VuexStore\n        RightPanel &lt;--&gt; VuexStore\n    end\n\n    %% 通信层\n    subgraph Communication [API and Communication FastAPI]\n        WS[WebSocket /ws/rag-tree\\nStream and Sync]\n        Static[HTTP /static\\nStatic Resources]\n    end\n\n    %% 后端/智能体层\n    subgraph Backend [Backend Multi-Agent AutoGen]\n        direction TB\n        ConnectionManager[Connection Manager\\nSocket Pool]\n        \n        subgraph Agents [Scientific Discovery Agents]\n            direction TB\n            Orchestrator[Orchestrator\\nStrategy and Planning]\n            ToolExecutor[ToolExecutor\\nSemantic and Metadata Search]\n            Evaluator[Evaluator\\nValue Assessment Grow/Keep/Prune]\n            HypothesisTeam[Hypothesis Team\\nSynthesis and Conclusion]\n            \n            Orchestrator --&gt;|Dispatch Search Strategy| ToolExecutor\n            ToolExecutor --&gt;|Raw Data| Evaluator\n            Evaluator --&gt;|Evaluation Feedback| Orchestrator\n            Evaluator --&gt;|High Value Nodes| HypothesisTeam\n        end\n    end\n\n    %% 数据底层\n    subgraph Storage [Data Infrastructure]\n        direction LR\n        LLM[External LLM\\nOpenAI Interface]\n        VectorDB[(VectorDB\\nChromaDB)]\n        LocalFiles[Local Files\\npaper_md / JSON / Images]\n    end\n\n    %% 关联连线\n    User &lt;--&gt;|Interact| LeftPanel\n    User &lt;--&gt;|Visualize and Select| CenterPanel\n    User &lt;--&gt;|Read Reports| RightPanel\n    \n    CenterPanel --&gt;|start_query / expand_search| WS\n    RightPanel --&gt;|Request Images| Static\n    WS &lt;--&gt; ConnectionManager\n    Static --&gt; LocalFiles\n    \n    ConnectionManager &lt;--&gt; Orchestrator\n    ConnectionManager &lt;--&gt; HypothesisTeam\n\n    ToolExecutor &lt;--&gt; VectorDB\n    ToolExecutor &lt;--&gt; LocalFiles\n    \n    Orchestrator &lt;--&gt; LLM\n    Evaluator &lt;--&gt; LLM\n    HypothesisTeam &lt;--&gt; LLM\n\n    %% 应用样式\n    class Frontend frontend\n    class Backend backend\n    class Agents agent\n    class Storage storage\n    class Communication comms&quot;,&#10;  &quot;config&quot;: {&#10;    &quot;theme&quot;: &quot;neutral&quot;,&#10;    &quot;arrowMarkerAbsolute&quot;: false,&#10;    &quot;flowchart&quot;: {&#10;      &quot;htmlLabels&quot;: false&#10;    },&#10;    &quot;sequence&quot;: {&#10;      &quot;diagramMarginX&quot;: 50,&#10;      &quot;diagramMarginY&quot;: 10,&#10;      &quot;actorMargin&quot;: 50,&#10;      &quot;width&quot;: 150,&#10;      &quot;height&quot;: 65,&#10;      &quot;boxMargin&quot;: 10,&#10;      &quot;boxTextMargin&quot;: 5,&#10;      &quot;noteMargin&quot;: 10,&#10;      &quot;messageMargin&quot;: 35,&#10;      &quot;mirrorActors&quot;: true,&#10;      &quot;bottomMarginAdj&quot;: 1,&#10;      &quot;useMaxWidth&quot;: true,&#10;      &quot;rightAngles&quot;: false,&#10;      &quot;showSequenceNumbers&quot;: false&#10;    },&#10;    &quot;gantt&quot;: {&#10;      &quot;titleTopMargin&quot;: 25,&#10;      &quot;barHeight&quot;: 20,&#10;      &quot;barGap&quot;: 4,&#10;      &quot;topPadding&quot;: 50,&#10;      &quot;leftPadding&quot;: 75,&#10;      &quot;gridLineStartPadding&quot;: 35,&#10;      &quot;fontSize&quot;: 11,&#10;      &quot;fontFamily&quot;: &quot;\&quot;Open-Sans\&quot;, \&quot;sans-serif\&quot;&quot;,&#10;      &quot;numberSectionStyles&quot;: 4,&#10;      &quot;axisFormat&quot;: &quot;%Y-%m-%d&quot;&#10;    },&#10;    &quot;securityLevel&quot;: &quot;strict&quot;,&#10;    &quot;startOnLoad&quot;: false,&#10;    &quot;themeVariables&quot;: {&#10;      &quot;primaryColor&quot;: &quot;#eee&quot;,&#10;      &quot;contrast&quot;: &quot;#707070&quot;,&#10;      &quot;secondaryColor&quot;: &quot;hsl(0, 0%, 98.9215686275%)&quot;,&#10;      &quot;background&quot;: &quot;#ffffff&quot;,&#10;      &quot;tertiaryColor&quot;: &quot;hsl(-160, 0%, 93.3333333333%)&quot;,&#10;      &quot;primaryBorderColor&quot;: &quot;hsl(0, 0%, 83.3333333333%)&quot;,&#10;      &quot;secondaryBorderColor&quot;: &quot;hsl(0, 0%, 88.9215686275%)&quot;,&#10;      &quot;tertiaryBorderColor&quot;: &quot;hsl(-160, 0%, 83.3333333333%)&quot;,&#10;      &quot;primaryTextColor&quot;: &quot;#111111&quot;,&#10;      &quot;secondaryTextColor&quot;: &quot;rgb(2.7499999999, 2.7499999999, 2.7499999999)&quot;,&#10;      &quot;tertiaryTextColor&quot;: &quot;rgb(17.0000000001, 17.0000000001, 17.0000000001)&quot;,&#10;      &quot;lineColor&quot;: &quot;#666&quot;,&#10;      &quot;textColor&quot;: &quot;#000000&quot;,&#10;      &quot;mainBkg&quot;: &quot;#eee&quot;,&#10;      &quot;secondBkg&quot;: &quot;hsl(0, 0%, 98.9215686275%)&quot;,&#10;      &quot;border1&quot;: &quot;#999&quot;,&#10;      &quot;border2&quot;: &quot;#707070&quot;,&#10;      &quot;note&quot;: &quot;#ffa&quot;,&#10;      &quot;text&quot;: &quot;#333&quot;,&#10;      &quot;critical&quot;: &quot;#d42&quot;,&#10;      &quot;done&quot;: &quot;#bbb&quot;,&#10;      &quot;arrowheadColor&quot;: &quot;#333333&quot;,&#10;      &quot;fontFamily&quot;: &quot;\&quot;trebuchet ms\&quot;, verdana, arial, sans-seri